# Riot API Configuration
# Get your API key from: https://developer.riotgames.com/
RIOT_API_KEY=RGAPI-your-api-key-here

# Flask Configuration
# Generate a secure secret key using: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# Region Settings
# Platform Region: euw1, eun1, na1, kr, br1, la1, la2, oc1, tr1, ru, jp1
PLATFORM_REGION=euw1

# Regional Routing: europe, americas, asia, sea
REGIONAL_ROUTING=europe

